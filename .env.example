# Kingsize Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection string (get from Neon dashboard → Connection Details)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# ── Integration provider ─────────────────────────────────────────────────────
# mock = use Neon mock catalog (local dev + staging)
# counterintelligence = use Counter Intelligence POS API (production)
INTEGRATION_PROVIDER=mock

# Toggle between mock catalog and real CI POS data
MOCK_CI_ENABLED=true

# Counter Intelligence POS (only required if INTEGRATION_PROVIDER=counterintelligence)
# CI_API_URL=https://api.counterintelligence.com.au
# CI_API_KEY=

# ── LLM provider ─────────────────────────────────────────────────────────────
# fallback = no LLM (rule-based only)
# groq = Groq API
# huggingface = Hugging Face Inference API
LLM_PROVIDER=fallback

# GROQ_API_KEY=
# HUGGINGFACE_API_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# Used by server components to call gateway routes via absolute URL.
# In Vercel this is set automatically via VERCEL_URL; override here for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
