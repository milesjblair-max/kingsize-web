# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing — generated artefacts, never commit these
/coverage
tests/report/
tests/results/
tests/screenshots/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Binary brand assets — serve from Cloudflare R2 / Vercel Blob in production
# Files still exist on local disk; not tracked in git to keep repo lean
Brand Logos/

# Source product image folders (processed copies live in public/images/)
ZIp Polo's 2025/
Zip Short's 2025/
Zip T-shirts 2025/
kingsize_logo_transparent_3000.2.png

# Server-side data store (local dev only)
.data/
